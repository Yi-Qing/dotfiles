{
    "layer": "top", // Waybar at top layer
    "spacing": 0,
    // "mode": "hide",
    // "start_hidden": true,
    "output": ["eDP-1", "VGA"],
    "modules-left": ["hyprland/workspaces", "hyprland/window", "mpd"],
    "modules-center": ["custom/clock"],
    "modules-right": ["network", "cpu", "memory", "temperature", "pulseaudio", "backlight", "battery", "tray"],
    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1": "юЩШ",
            "2": "юШл",
            "3": "яТЙ",
            "4": "юЪЯ",
            "5": "юШЩ",
            "6": "яВ▒",
            "7": "юКЭ",
		    "8": "яВЖ",
            "9": "яАБ",
            "10": "юШк",
            "default": "яДС"
        } 
    },
    "hyprland/window": {
        "format": "{class} тШп",
        "rewrite": {
            "codium-url-handler (.*)": "Code $1"
        },
        "separate-outputs": true
    },
    "mpd": {
        "format": "яАБ {title} - {artist}{singleIcon}",
        "format-paused": "",
        "max-length": 35,
        "single-icons": {
            "on": "яАЮ"
        },
        "on-click-right": "mpc toggle",
        "tooltip-format": "яАБ {title} - {artist}\nяАз {volume}\t{elapsedTime:%M:%S}/{totalTime:%M:%S}\t┬л{songPosition}/{queueLength}┬╗"
    },
    "custom/clock": {
        "interval": 1,
        "escape": true,
        "return-type": "json",
        "format": "{}",
        "format-alt": "{alt}",
        "exec": "~/.config/waybar/clock.sh",
        "exec-on-event": false
    },
    "network": {
        "interval": 1,
        "format-wifi": "{bandwidthTotalBytes} яЗл",
        "format-ethernet": "{bandwidthTotalBytes} яГи",
        "tooltip-format": "{ifname} via {gwaddr}",
        "format-linked": "{ifname} (No IP) тЪа",
        "format-disconnected": "Disconnected тЪа",
        "format-alt": "{ifname}: {ipaddr}"
    },
    "cpu": {
        "interval": 3,
        "format": "{usage}% {icon}",
        "format-icons": [
            "<span color='#69ff94'>тЦБ</span>", // green
            "<span color='#2aa9ff'>тЦВ</span>", // blue
            "<span color='#f8f8f2'>тЦГ</span>", // white
            "<span color='#f8f8f2'>тЦД</span>", // white
            "<span color='#ffffa5'>тЦЕ</span>", // yellow
            "<span color='#ffffa5'>тЦЖ</span>", // yellow
            "<span color='#ff9977'>тЦЗ</span>", // orange
            "<span color='#dd532e'>тЦИ</span>"  // red
        ]
    },
    "memory": {
        "format": "{percentage}% яГЙ",
        "tooltip-format": "{used:0.1f}G/{total:0.1f}G яГЙ"
    },
    "temperature": {
        "critical-threshold": 80,
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": ["яЛЙ"]
    },
    "pulseaudio": {
        "max-volume": 150,
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
        "format-bluetooth-muted": "яСж {icon}яКФ {format_source}",
        "format-muted": "яСж  {format_source}",
        "format-source": "{volume}% яД░",
        "format-source-muted": "яД▒",
        "format-icons": {
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click": "pavucontrol",
        "on-click-right": "qpwgraph"    // helvum
    },
    "backlight": {
        "format": "{percent}% {icon}",
        "reverse-scrolling": true,
        "reverse-mouse-scrolling": true,
        "format-icons": ["юПХ", "юПЦ", "юПШ", "юПЩ", "юПЫ", "юПЮ", "юПЯ", "юПа", "юПв", "юПг"]

    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% яГз",
        "format-plugged": "{capacity}% яЗж",
        "format-alt": "{time} {icon}",
        "format-good": "", // An empty format will hide the module
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "tray": {
        "spacing": 10
    }
}

